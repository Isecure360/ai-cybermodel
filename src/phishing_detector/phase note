import joblib
import json
import os

MODEL_DIR = "models"

def load_model():
    with open(os.path.join(MODEL_DIR, "registry.json")) as f:
        registry = json.load(f)

    model_path = os.path.join(MODEL_DIR, registry["active_model"])
    features_path = os.path.join(MODEL_DIR, registry["feature_version"])

    model = joblib.load(model_path)
    features = joblib.load(features_path)

    return model, features
🧠 PHASE 4 — PREDICTOR SERVICE

📍 app/services/predictor.py

This is your brain wrapper.

from app.services.model_loader import load_model
from app.services.feature_engineering import extract_features_from_url
import pandas as pd

model, feature_columns = load_model()

def predict_url(url: str):
    features_dict = extract_features_from_url(url)

    df = pd.DataFrame([features_dict])

    # Ensure correct column order
    df = df[feature_columns]

    prediction = model.predict(df)[0]
    probability = model.predict_proba(df)[0][1]

    return {
        "prediction": int(prediction),
        "probability": float(probability)
    }
